# Supabase Configuration
# Get these values from: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Sync API base URL (backend API root, do NOT include /app)
# Leave empty to use local default http://localhost:3001
# CI injects https://dev.word-base.pages.dev for dev and https://word-base.pages.dev for main/tags
# SYNC_BASE_URL=http://localhost:3001

# WordBase frontend app URL (for logo link and login redirect)
# Leave empty to use local default http://localhost:3000/app
# CI injects https://dev.word-base.pages.dev/app for dev and https://word-base.pages.dev/app for main/tags
# WORD_BASE_APP_URL=http://localhost:3000/app
