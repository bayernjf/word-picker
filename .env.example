# Supabase Configuration
# Get these values from: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Sync API base URL (backend API root, do NOT include /app)
# Leave empty to use production default https://word-base.pages.dev
# SYNC_BASE_URL=https://word-base.pages.dev

# WordBase frontend app URL (for logo link and login redirect)
# Leave empty to use production default https://word-base.pages.dev/app
# WORD_BASE_APP_URL=https://word-base.pages.dev/app
